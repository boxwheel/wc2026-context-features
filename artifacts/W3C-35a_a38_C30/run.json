{
  "experiment": "W3C-35a_a38_C30",
  "script": "wave3-context/code/run_w3c35.py",
  "repo": "https://github.com/boxwheel/wc2026-context-features",
  "features": ["elo_diff", "host_advantage", "rank_diff", "mv_top11_diff", "gk_mv_diff", "rest_diff", "venue_elevation"],
