  "wilcoxon_vs_frontier_pvalue": 0.0984,
  "data": "build_match_features(include_context=True), n=64 WC-2026 group-stage matches",
  "leakage_check": "context features are all pre-match only (rest_diff=days since last match, venue_elevation=stadium altitude)"
}
